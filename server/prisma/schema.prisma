generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  role     Role    @default(EMPLOYEE)
  isActive Boolean @default(true)

  garageVisits GarageVisit[]
  attendance   EmployeeAttendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarageVisit {
  id String @id @default(cuid())

  shopName String
  address  String

  location String?

  phoneNumber String

  leadStatus LeadStatus @default(PENDING)

  notes String?

  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  images GarageImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarageImage {
  id String @id @default(cuid())

  imageUrl String

  publicId String?

  garageVisitId String
  garageVisit   GarageVisit @relation(fields: [garageVisitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LeadStatus {
  PENDING
  INTERESTED
  FOLLOW_UP
  CONVERTED
  REJECTED
}

model EmployeeAttendance {
  id String @id @default(cuid())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  checkInTime DateTime?

  checkOutTime DateTime?

  status AttendanceStatus @default(CHECKED_OUT)

  createdAt DateTime @default(now())
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}
