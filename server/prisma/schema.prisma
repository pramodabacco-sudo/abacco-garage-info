generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  role     Role    @default(EMPLOYEE)
  isActive Boolean @default(true)

  garageVisits GarageVisit[]
  attendance   EmployeeAttendance[]
  locations    EmployeeLocation[]
  schools      School[]
  vehicles     Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarageVisit {
  id String @id @default(cuid())

  shopName String
  address  String

  location String?

  phoneNumber String

  garageType String?

  leadStatus LeadStatus @default(FIRST_VISIT)

  followUpDate DateTime?
  notes        String?

  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  images GarageImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarageImage {
  id String @id @default(cuid())

  imageUrl String

  publicId String?

  garageVisitId String
  garageVisit   GarageVisit @relation(fields: [garageVisitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LeadStatus {
  FIRST_VISIT
  INTERESTED
  FOLLOW_UP
  DEAL
  NOT_INTERESTED
}

model School {
  id String @id @default(cuid())

  schoolName    String
  contactPerson String?
  designation   String?

  phoneNumber String?
  email       String?

  address  String?
  city     String?
  district String?
  state    String?

  // GPS Location
  latitude  Float?
  longitude Float?

  responseStatus SchoolResponseStatus @default(NOT_CONTACTED)

  followUpDate DateTime?
  notes        String?

  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  images SchoolImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([responseStatus])
  @@index([followUpDate])
}

model SchoolImage {
  id String @id @default(cuid())

  imageUrl String
  publicId String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum SchoolResponseStatus {
  NOT_CONTACTED
  VISITED
  INTERESTED
  DEMO_SCHEDULED
  FOLLOW_UP
  NOT_INTERESTED
  CUSTOMER
}

model EmployeeAttendance {
  id String @id @default(cuid())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  checkInTime DateTime?

  checkOutTime DateTime?

  locations EmployeeLocation[]

  status AttendanceStatus @default(CHECKED_OUT)

  createdAt DateTime @default(now())
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}

model EmployeeLocation {
  id String @id @default(cuid())

  userId       String
  attendanceId String

  // GPS Location
  latitude  Float?
  longitude Float?

  address String?

  // Manual Location
  manualLocation String?
  remarks        String?

  isManual Boolean @default(false)

  createdAt DateTime @default(now())

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance EmployeeAttendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([attendanceId])
  @@index([createdAt])
}

model Vehicle {
  id String @id @default(cuid())

  name  String // e.g. "Delivery Scooty 1"
  regNo String @unique // e.g. "KA50EL0766" — matched against GPS API response

  isActive Boolean @default(true)

  // Link to the employee this vehicle is assigned to
  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Convenience snapshot of the LATEST known location (avoids extra query on list view)
  latestLatitude  Float?
  latestLongitude Float?
  latestSpeed     Float?
  latestAddress   String?
  latestStatus    VehicleStatus?
  latestIgnition  String?
  lastSeenAt      DateTime?

  locations VehicleLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
}

model VehicleLocation {
  id String @id @default(cuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  regNo String // denormalized for quick lookup/debug

  latitude  Float?
  longitude Float?
  speed     Float?
  bearing   Float?

  status         String?
  ignitionStatus String?
  vehicleStatus  VehicleStatus?

  address     String?
  odoDistance Float?
  fuelLitre   Float?

  gpsTimestamp DateTime? // isoDate from GPS API (when the reading was taken)

  rawData Json? // full API object for that vehicle, for debugging

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([regNo])
  @@index([createdAt])
}

enum VehicleStatus {
  MOVING
  PARKED
  IDLE
  OFF
  NODATA
}
